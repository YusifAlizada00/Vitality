# Copy to `.env.local` and fill in (never commit `.env.local`).
# Get a key: https://aistudio.google.com/app/apikey

# Google Gemini (Generative Language API) — optional coach / copy layer
GEMINI_API_KEY=

# Optional: model id (default gemini-1.5-flash). Examples: gemini-1.5-flash, gemini-2.0-flash
# GEMINI_MODEL=
